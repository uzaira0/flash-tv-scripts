# FLASH-TV Environment Configuration
# Copy this file to .env and fill in the values for your deployment.
#
# Usage:
#   cp .env.example .env
#   nano .env  # Edit values
#   docker compose up -d

# =============================================================================
# Required: Identity Configuration
# =============================================================================

# Participant ID (e.g., "P1-3999" for TECH study, "ES-1234" for ESS study)
PARTICIPANT_ID=P1-0000

# Device ID - last 3 digits of the username (e.g., "028" for flashsys028)
DEVICE_ID=000

# System username (e.g., "flashsys028")
FLASH_USERNAME=flashsys000

# =============================================================================
# Optional: Override Defaults
# =============================================================================

# Uncomment to override default configuration file location
# FLASH_CONFIG_PATH=/path/to/custom/flash_config.yaml

# Uncomment to enable debug image saving
# FLASH_SAVE_IMAGES=true

# Uncomment to change log level (DEBUG, INFO, WARNING, ERROR)
# FLASH_LOG_LEVEL=INFO
